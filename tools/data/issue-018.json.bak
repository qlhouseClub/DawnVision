      "word_count": 790,
      "sources": [
        {
          "text": "The Verge - China delivers a one-two punch to America's AI dominance",
          "url": "https://www.theverge.com/ai-artificial-intelligence/967781/chinese-ai-models-open-source-moonshot-kimi-k3-alibaba-qwen"
        },
        {
          "text": "36氪 - 月之暗面黄震昕：B端收入中API调用占比达70%",
          "url": "https://36kr.com/newsflashes/3905023017256583"
        },
        {
          "text": "36氪 - 智谱午后涨超30%",
          "url": "https://36kr.com/newsflashes/3904938601973633"
