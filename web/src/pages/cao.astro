---
import BaseLayout from '@layouts/BaseLayout.astro';
import ArticleCard from '@components/ArticleCard.astro';
import BackgroundBlobs from '@components/BackgroundBlobs.astro';
import { getAllCaos } from '@lib/issues';
import '@styles/pages/cao.css';

const caos = await getAllCaos();

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Cao! 槽点 — Dawn Vision",
  "description": "每天一点槽，笑完继续搞。AI吐槽专栏，科技圈翻车现场，AI编程翻车、AI产品吐槽、AI行业趣闻。A little rant a day keeps the sanity away. We roast AI so you don't have to.",
  "url": "https://www.dawnvision.net/cao",
  "isPartOf": { "@type": "WebSite", "name": "Dawn Vision", "url": "https://www.dawnvision.net/" }
});
---

<BaseLayout
  title="Cao! 槽点"
  description="每天一点槽，笑完继续搞。Dawn Vision吐槽专栏，AI编程翻车、AI产品吐槽、科技圈趣闻。AI fails, tech rant, AI humor."
  navVariant="inner"
  activeNav="cao"
  structuredData={jsonLd}
>
  <Fragment slot="main">
    <div class="cao-page">
      {/* Cao Hero (full-bleed Klein blue, matching articles page Cao section) */}
      <section class="cao-hero">
        <BackgroundBlobs variant="section" />
        <div class="cao-page__container" style="position:relative;z-index:1;">
          <h1 class="cao-hero__title notranslate" translate="no">Cao! <em>槽点!</em></h1>
          <p class="cao-hero__subtitle">每天一点槽，笑完继续搞。</p>
          <p class="cao-hero__subtitle-en notranslate" translate="no">A little rant a day keeps the sanity away. We roast AI so you don't have to.</p>
        </div>
      </section>

      {/* Cao Article List (flat list, no latest/archive split) */}
      <div class="cao-page__body">
        <div class="cao-page__container">
          {caos.length > 0 ? (
            <div class="cao-list">
              {caos.map((cao) => (
                <ArticleCard
                  variant="cao-item"
                  article={cao}
                  issueNum={cao.issueNum}
                  issueDate={cao.issueDate}
                  href={`/articles/${cao.slug}`}
                />
              ))}
            </div>
          ) : (
            <div style="padding: 80px 0; text-align: center; color: var(--color-text-muted); font-style: italic;">
              暂无Cao专栏内容
            </div>
          )}
        </div>
      </div>
    </div>
  </Fragment>
</BaseLayout>
