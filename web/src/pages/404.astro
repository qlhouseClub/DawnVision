---
import BaseLayout from '@layouts/BaseLayout.astro';
import '@styles/pages/error.css';
---

<BaseLayout
  title="404 — 页面不存在"
  description="这页穿越到未来了"
  navVariant="home"
  noindex={true}
>
  <Fragment slot="main">
    <div class="error-page error-page--404">
      <div class="error-page__code">404</div>
      <h1 class="error-page__title">这页穿越到未来了</h1>
      <p class="error-page__desc">你访问的页面不存在，或许它还没被写出来。</p>
      <div class="error-page__actions">
        <a href="/" class="error-page__btn error-page__btn--primary">回到首页</a>
        <a href="/articles" class="error-page__btn error-page__btn--ghost">最新文章</a>
      </div>
    </div>
  </Fragment>
</BaseLayout>
