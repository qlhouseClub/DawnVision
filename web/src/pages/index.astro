---
import BaseLayout from '@layouts/BaseLayout.astro';
import BackgroundBlobs from '@components/BackgroundBlobs.astro';
import { getLatestIssue } from '@lib/issues';
import { buildWebsiteJsonLd } from '@lib/seo';
import '@styles/pages/home.css';

const latest = await getLatestIssue();
const cover = latest.data.cover;

const jsonLd = JSON.stringify(buildWebsiteJsonLd());
---

<BaseLayout
  title="Dawn Vision"
  description="Dawn Vision — AI深度观察日刊，每日精选AI行业焦点，穿透信息噪声，穿越嘈杂，洞见留声。焦点资讯+槽点吐槽，AI news & tech rant."
  titleEn="Dawn Vision"
  descriptionEn="Dawn Vision — AI Insight Daily. Curated AI industry focus, cutting through the noise. Focus news + tech roasts."
  navVariant="home"
  activeNav="home"
  structuredData={jsonLd}
>
  <Fragment slot="main">
    <div class="home-page__hero" style="position:relative;">
      <BackgroundBlobs variant="home" />

      <div class="home-page__content">
        <!-- Search trigger button above cover -->
        <button class="home-page__search-trigger notranslate" id="home-search-btn" aria-label="Search articles">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/>
            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <span>Search</span>
          <kbd>⌘K</kbd>
        </button>

        <!-- Today's cover teaser card -->
        <article class="home-page__teaser" itemscope itemtype="https://schema.org/NewsArticle">
          <div class="home-page__teaser-label notranslate">Focus · <span class="dv-zh">焦点</span></div>
          <h2 class="home-page__teaser-title" itemprop="headline">
            <span class="dv-zh">{cover.title_short || cover.title}</span>
            {cover.title_short_en && <span class="dv-en">{cover.title_short_en || cover.title_en}</span>}
          </h2>
          <p class="home-page__teaser-deck dv-zh" itemprop="description">{cover.deck}</p>
          {cover.deck_en && <p class="home-page__teaser-deck dv-en" itemprop="description">{cover.deck_en}</p>}
          <meta itemprop="datePublished" content={latest.data.issue.date} />
          <meta itemprop="author" content="Dawn Vision 编辑部" />
          <a href={`/articles/${cover.slug}/`} class="home-page__teaser-btn notranslate" itemprop="url">
            Read More <span class="arrow">→</span>
          </a>
        </article>

        <h1 class="home-page__title notranslate">
          Through the Clamor,<br>
          Insight Echoes.<br>
          Read.
        </h1>

        <p class="home-page__tagline dv-zh">穿越嘈杂，<br>洞见留声。</p>

        <h2 class="sr-only">
          Dawn Vision — AI 深度观察日刊，每个工作日深度解读 AI 前沿资讯：AI Agent、大模型、具身智能、AI 商业化、一人公司
        </h2>
      </div>
    </div>
  </Fragment>
</BaseLayout>
