---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getLatestIssue } from '@lib/issues';
import '@styles/pages/home.css';

const latest = await getLatestIssue();
const cover = latest.data.cover;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Dawn Vision",
  "alternateName": "DawnVision",
  "url": "https://www.dawnvision.net/",
  "description": "穿越嘈杂，洞见留声。AI时代的深度阅读日刊，每个工作日深度解读AI前沿。",
  "inLanguage": "zh-CN",
  "publisher": {
    "@type": "Organization",
    "name": "Dawn Vision",
    "url": "https://www.dawnvision.net/",
    "logo": {
      "@type": "ImageObject",
      "url": "https://www.dawnvision.net/images/og-image.png",
      "width": 1200,
      "height": 630
    }
  }
});
---

<BaseLayout
  title="Dawn Vision"
  description="Dawn Vision — AI深度观察日刊，每日精选AI行业焦点，穿透信息噪声，穿越嘈杂，洞见留声。"
  navVariant="home"
  activeNav="home"
  footerVariant="home"
  structuredData={jsonLd}
>
  <Fragment slot="main">
    <div class="home-page__hero">
      <!-- Today's cover teaser card -->
      <article class="home-page__teaser" itemscope itemtype="https://schema.org/NewsArticle">
        <div class="home-page__teaser-label">Focus · 焦点</div>
        <h2 class="home-page__teaser-title" itemprop="headline">{cover.title}</h2>
        <p class="home-page__teaser-deck" itemprop="description">{cover.deck}</p>
        <meta itemprop="datePublished" content={latest.data.issue.date} />
        <meta itemprop="author" content="Dawn Vision 编辑部" />
        <a href={`/articles/${cover.slug}`} class="home-page__teaser-link" itemprop="url">
          Read More <span class="arrow">→</span>
        </a>
      </article>

      <h1 class="home-page__title">
        Through the Clamor,<br>
        Insight Echoes.<br>
        Read.
      </h1>

      <p class="home-page__tagline">穿越嘈杂，<br>洞见留声。</p>

      <h2 class="sr-only">
        Dawn Vision — AI 深度观察日刊，每个工作日深度解读 AI 前沿资讯：AI Agent、大模型、具身智能、AI 商业化、一人公司
      </h2>
    </div>
  </Fragment>
</BaseLayout>
