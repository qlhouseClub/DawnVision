---
import BaseLayout from '@layouts/BaseLayout.astro';
import '@styles/pages/error.css';
---

<BaseLayout
  title="502 — 网关错误"
  description="服务暂时无法访问"
  navVariant="inner"
  noindex={true}
>
  <Fragment slot="main">
    <div class="error-page error-page--5xx">
      <div class="error-page__code">502</div>
      <h1 class="error-page__title">暂时无法访问</h1>
      <p class="error-page__desc">网关出了点问题，服务暂时不可用。请稍后重试。</p>
      <div class="error-page__actions">
        <a href="/" class="error-page__btn error-page__btn--primary">回到首页</a>
        <a href="javascript:location.reload()" class="error-page__btn error-page__btn--ghost">重新加载</a>
      </div>
    </div>
  </Fragment>
</BaseLayout>
