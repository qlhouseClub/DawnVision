---
import BaseLayout from '@layouts/BaseLayout.astro';
import '@styles/pages/about.css';

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About — Dawn Vision",
  "description": "关于Dawn Vision——在噪音中看见信号，AI时代的深度观察日刊。",
  "url": "https://www.dawnvision.net/about",
  "publisher": {
    "@type": "Organization",
    "name": "Dawn Vision",
    "url": "https://www.dawnvision.net/"
  }
});
---

<BaseLayout
  title="About · 关于"
  description="关于Dawn Vision——在噪音中看见信号，AI时代的深度观察日刊。"
  navVariant="inner"
  activeNav="about"
  structuredData={jsonLd}
>
  <Fragment slot="main">
    <div class="about-page">
      <!-- Title -->
      <h1 class="about-page__title notranslate" translate="no">Dawn Vision</h1>
      <div class="about-page__eyebrow notranslate" translate="no">About the Author</div>

      <!-- Author tags (italic, gray, centered) -->
      <ul class="about-page__tags">
        <li>水瓶座、天马行空的设计师</li>
        <li class="notranslate" translate="no">INFP (MBTI)、MUM (SBTI)</li>
        <li>认错超快叛逆不改气人天赋高超的心理砖家</li>
        <li>视角独特且薄学的不才写手</li>
        <li>仗势AI冲浪的技术小白</li>
      </ul>

      <!-- Blue divider -->
      <div class="about-page__divider"></div>

      <!-- Description paragraph -->
      <p class="about-page__desc">
        Dawn Vision 是一份 AI 深度观察日刊；<br>
        关注每天 AI 相关的前沿话题。
      </p>

      <!-- Contact -->
      <div class="about-page__contact">
        <div class="about-page__contact-item">
          <div class="about-page__contact-value notranslate" translate="no">DawnVision88</div>
          <div class="about-page__contact-label notranslate" translate="no">Wechat</div>
        </div>
        <div class="about-page__contact-item">
          <a href="tel:18622454349" class="about-page__contact-value about-page__contact-value--link notranslate" translate="no">18622454349</a>
          <div class="about-page__contact-label notranslate" translate="no">Phone</div>
        </div>
      </div>

      <!-- Tip Jar -->
      <div class="about-page__tipjar">
        <div class="about-page__tipjar-label notranslate" translate="no">Tip Jar</div>
        <div class="about-page__qr-wrap">
          <img src="/images/reward-qr.webp" alt="谢谢老板请我喝奶茶" class="about-page__qr" width="220" height="220" loading="lazy" />
        </div>
        <p class="about-page__tipjar-quote">"谢谢老板请我喝奶茶"</p>
      </div>
    </div>
  </Fragment>
</BaseLayout>
