---
import BaseLayout from '@layouts/BaseLayout.astro';
import '@styles/pages/error.css';
---

<BaseLayout
  title="500 — 服务器错误"
  description="服务器开小差了"
  navVariant="inner"
  noindex={true}
>
  <Fragment slot="main">
    <div class="error-page error-page--5xx">
      <div class="error-page__code">500</div>
      <h1 class="error-page__title">服务器开小差了</h1>
      <p class="error-page__desc">抱歉，服务器内部出了点问题。请稍后重试，或者回到首页继续阅读。</p>
      <div class="error-page__actions">
        <a href="/" class="error-page__btn error-page__btn--primary">回到首页</a>
        <a href="javascript:location.reload()" class="error-page__btn error-page__btn--ghost">重新加载</a>
      </div>
    </div>
  </Fragment>
</BaseLayout>
