---
import BaseLayout from '@layouts/BaseLayout.astro';
import BackgroundBlobs from '@components/BackgroundBlobs.astro';
import { getAllIssues } from '@lib/issues';
import { buildNewsArticleJsonLd, buildBreadcrumbJsonLd } from '@lib/seo';
import '@styles/components/article.css';

export async function getStaticPaths() {
  const issues = await getAllIssues();
  const paths: { params: { slug: string }; props: any }[] = [];

  // Build a flat list of all articles in order (newest first) for prev/next
  const allArticles: { slug: string; title: string; type: string }[] = [];

  for (const issue of issues) {
    // Cover
    const coverPath = {
      params: { slug: issue.data.cover.slug },
      props: {
        article: issue.data.cover,
        type: 'cover' as const,
        issueNum: issue.data.issue.number,
        issueDate: issue.data.issue.date_display,
        issueDateIso: issue.data.issue.date,
        category: 'Focus · 焦点',
      }
    };
    paths.push(coverPath);
    allArticles.push({ slug: issue.data.cover.slug, title: issue.data.cover.title, type: 'cover' });

    // Briefs
    for (const brief of issue.data.briefs) {
      paths.push({
        params: { slug: brief.slug },
        props: {
          article: brief,
          type: 'brief' as const,
          issueNum: issue.data.issue.number,
          issueDate: issue.data.issue.date_display,
          issueDateIso: issue.data.issue.date,
          category: brief.category_en || brief.category,
        }
      });
      allArticles.push({ slug: brief.slug, title: brief.title, type: 'brief' });
    }

    // Cao
    if (issue.data.cao) {
      paths.push({
        params: { slug: issue.data.cao.slug },
        props: {
          article: issue.data.cao,
          type: 'cao' as const,
          issueNum: issue.data.issue.number,
          issueDate: issue.data.issue.date_display,
          issueDateIso: issue.data.issue.date,
          category: 'Cao! · 操蛇之神',
        }
      });
      allArticles.push({ slug: issue.data.cao.slug, title: issue.data.cao.title, type: 'cao' });
    }
  }

  // Add prev/next to each path's props
  for (const p of paths) {
    const idx = allArticles.findIndex(a => a.slug === p.params.slug);
    // In reading order (newest first): prev = older article (idx+1), next = newer article (idx-1)
    p.props.prevArticle = idx < allArticles.length - 1 ? allArticles[idx + 1] : null;
    p.props.nextArticle = idx > 0 ? allArticles[idx - 1] : null;
  }

  return paths;
}

const { article, type, issueNum, issueDate, issueDateIso, category, prevArticle, nextArticle } = Astro.props;
const isCao = type === 'cao';

const pageTitle = article.title_short || article.title;
const pageDescription = article.og_description || article.deck;
const pageUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://www.dawnvision.net').toString();

const articleLd = JSON.stringify(buildNewsArticleJsonLd(
  article,
  { number: issueNum, date: issueDateIso, date_display: issueDate },
  category,
));

const breadcrumbLd = JSON.stringify(buildBreadcrumbJsonLd([
  { name: '首页', url: 'https://www.dawnvision.net/' },
  { name: '文章', url: 'https://www.dawnvision.net/articles' },
  { name: pageTitle },
]));

const jsonLdArray = [articleLd, breadcrumbLd];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  navVariant="inner"
  activeNav={isCao ? 'cao' : 'articles'}
  type="article"
  canonical={pageUrl}
  structuredData={jsonLdArray}
>
  <Fragment slot="main">
    {/* Article Hero */}
    <section class={`article-hero ${isCao ? 'article-hero--cao' : ''}`}>
      <BackgroundBlobs variant="section" />
      <div class="container--narrow" style="position:relative;z-index:1;">
        <div class="article-hero__category notranslate" data-pagefind-meta="category" translate="no">{category}</div>
        <h1 class="article-hero__title" data-pagefind-meta="title" set:html={article.title_break || article.title}></h1>
        <p class="article-hero__deck">{article.deck}</p>
        <div class="article-hero__meta">
          <span class="article-hero__issue notranslate" translate="no">No.{issueNum}</span>
          <span>{issueDate}</span>
          <span>{article.read_time}</span>
        </div>
      </div>
    </section>

    {/* Article Body */}
    <article class="container--narrow" style="padding-top: clamp(40px, 6vw, 64px); padding-bottom: 0;">
      <div class="article-body" data-pagefind-body set:html={article.body_html}></div>

      {/* Pull Quote */}
      {article.pull_quote && (
        <blockquote class="article-pull-quote">
          <p class="article-pull-quote__text">{article.pull_quote.text}</p>
          {article.pull_quote.attr && (
            <cite class="article-pull-quote__attr">{article.pull_quote.attr}</cite>
          )}
        </blockquote>
      )}

      {/* Cao Footnote Tip */}
      {isCao && article.footnote_tip && (
        <div class="article-cao-tip">{article.footnote_tip}</div>
      )}

      {/* Cognitive Notes */}
      {article.cognitive_notes && (
        <div class="article-cognitive">{article.cognitive_notes}</div>
      )}

      {/* Sources */}
      {article.sources && article.sources.length > 0 && (
        <div class="article-sources">
          <div class="article-sources__title notranslate" translate="no">Sources · 信源</div>
          <ul class="article-sources__list">
            {article.sources.map((source: { text: string; url: string }) => (
              <li class="article-sources__item">
                {source.url ? (
                  <a href={source.url} target="_blank" rel="noopener noreferrer">{source.text}</a>
                ) : (
                  source.text
                )}
              </li>
            ))}
          </ul>
          {article.source_summary && (
            <p class="article-source-summary">{article.source_summary}</p>
          )}
        </div>
      )}

      {/* Article Actions: Like + Tip */}
      <div class="article-actions">
        <button class="article-action-btn article-action-btn--like" id="article-like-btn" data-slug={article.slug} aria-label="喜欢这篇文章">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
          <span class="article-action-btn__label">喜欢</span>
          <span class="article-action-btn__count" id="like-count">0</span>
        </button>
        <button class="article-action-btn article-action-btn--tip" id="article-tip-btn" aria-label="打赏">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
          <span class="article-action-btn__label">打赏</span>
        </button>
      </div>

      {/* Prev / Next Navigation */}
      <nav class="article-nav" aria-label="文章导航">
        {prevArticle ? (
          <a href={`/articles/${prevArticle.slug}`} class="article-nav__item article-nav__item--prev">
            <div class="article-nav__label">上一篇</div>
            <div class="article-nav__title">{prevArticle.title}</div>
          </a>
        ) : <div></div>}
        {nextArticle ? (
          <a href={`/articles/${nextArticle.slug}`} class="article-nav__item article-nav__item--next">
            <div class="article-nav__label">下一篇</div>
            <div class="article-nav__title">{nextArticle.title}</div>
          </a>
        ) : <div></div>}
      </nav>
    </article>
  </Fragment>
</BaseLayout>
