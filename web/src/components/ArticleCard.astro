---
/**
 * ArticleCard — 文章卡片（支持中英双语）
 * @param variant 'cover' | 'grid' | 'brief' | 'cao-item'
 */
import '@styles/components/article-card.css';

export interface Props {
  variant?: 'cover' | 'grid' | 'brief' | 'cao-item';
  article: {
    slug: string;
    title: string;
    deck: string;
    title_en?: string;
    deck_en?: string;
    category?: string;
    category_en?: string;
    read_time?: string;
    read_time_en?: string;
  };
  issueNum?: string | number;
  issueDate?: string;
  href?: string;
  showCategory?: boolean;
}

const {
  variant = 'grid',
  article,
  issueNum,
  issueDate,
  href = `/articles/${article.slug}/`,
  showCategory = true,
} = Astro.props;

function pad(n: string | number) {
  return String(n).padStart(3, '0');
}

function formatDate(dateStr?: string) {
  if (!dateStr) return '';
  return dateStr.replace(/-/g, '.');
}

const categoryText = article.category || '';
const categoryEn = article.category_en || '';
const hasEn = !!(article.title_en && article.deck_en);
---

<article class={`card card--${variant}`}>
  {variant === 'grid' ? (
    <Fragment>
      {showCategory && categoryText && (
        <Fragment>
          <span class="card__tag dv-zh">{categoryText}</span>
          {hasEn && categoryEn && <span class="card__tag dv-en">{categoryEn}</span>}
        </Fragment>
      )}
      <h3 class="card__title">
        <a href={href}>
          <span class="dv-zh" set:html={article.title}></span>
          {hasEn && <span class="dv-en" set:html={article.title_en}></span>}
        </a>
      </h3>
      <p class="card__deck dv-zh">{article.deck}</p>
      {hasEn && <p class="card__deck dv-en">{article.deck_en}</p>}
    </Fragment>
  ) : variant === 'cao-item' ? (
    <Fragment>
      <div class="card__meta notranslate">
        {issueNum && <span>Issue {pad(issueNum)} · {formatDate(issueDate)}</span>}
      </div>
      <h3 class="card__title">
        <a href={href}>
          <span class="dv-zh" set:html={article.title}></span>
          {hasEn && <span class="dv-en" set:html={article.title_en}></span>}
        </a>
      </h3>
      <p class="card__deck dv-zh">{article.deck}</p>
      {hasEn && <p class="card__deck dv-en">{article.deck_en}</p>}
    </Fragment>
  ) : variant === 'cover' ? (
    <Fragment>
      <h3 class="card__title">
        <a href={href}>
          <span class="dv-zh" set:html={article.title}></span>
          {hasEn && <span class="dv-en" set:html={article.title_en}></span>}
        </a>
      </h3>
      <p class="card__deck dv-zh">{article.deck}</p>
      {hasEn && <p class="card__deck dv-en">{article.deck_en}</p>}
      <div class="card__byline">
        <a href={href}>
          <span class="dv-zh">Dawn Vision · {article.read_time} →</span>
          {hasEn && <span class="dv-en">Dawn Vision · {article.read_time_en || '~5 min read'} →</span>}
        </a>
      </div>
    </Fragment>
  ) : (
    <Fragment>
      {showCategory && categoryText && (
        <Fragment>
          <div class="card__category dv-zh">{categoryText}</div>
          {hasEn && categoryEn && <div class="card__category dv-en">{categoryEn}</div>}
        </Fragment>
      )}
      <h3 class="card__title">
        <a href={href}>
          <span class="dv-zh" set:html={article.title}></span>
          {hasEn && <span class="dv-en" set:html={article.title_en}></span>}
        </a>
      </h3>
      <p class="card__deck dv-zh">{article.deck}</p>
      {hasEn && <p class="card__deck dv-en">{article.deck_en}</p>}
    </Fragment>
  )}
</article>
