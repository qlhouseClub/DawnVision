---
/**
 * ArticleCard — 文章卡片
 * @param variant 'cover' | 'grid' | 'brief' | 'cao-item'
 *   - cover: Focus封面大卡片
 *   - grid: Brief网格卡片（标签tag显示中文分类）
 *   - cao-item: Cao列表项
 * @param article 文章数据
 * @param issueNum 期数号
 * @param issueDate 期数日期显示
 * @param showCategory 是否显示分类标签
 */
import '@styles/components/article-card.css';

export interface Props {
  variant?: 'cover' | 'grid' | 'brief' | 'cao-item';
  article: {
    slug: string;
    title: string;
    deck: string;
    category?: string;
    category_en?: string;
    read_time?: string;
  };
  issueNum?: string | number;
  issueDate?: string;
  href?: string;
  showCategory?: boolean;
}

const {
  variant = 'grid',
  article,
  issueNum,
  issueDate,
  href = `/articles/${article.slug}`,
  showCategory = true,
} = Astro.props;

function pad(n: string | number) {
  return String(n).padStart(3, '0');
}

// Format date as YYYY.MM.DD for display
function formatDate(dateStr?: string) {
  if (!dateStr) return '';
  return dateStr.replace(/-/g, '.');
}

// Chinese-only category for grid cards (translation support)
const categoryText = article.category || '';
---

<article class={`card card--${variant}`}>
  {variant === 'grid' ? (
    <Fragment>
      {showCategory && categoryText && (
        <span class="card__tag">{categoryText}</span>
      )}
      <h3 class="card__title">
        <a href={href} set:html={article.title} />
      </h3>
      <p class="card__deck">{article.deck}</p>
    </Fragment>
  ) : variant === 'cao-item' ? (
    <Fragment>
      <div class="card__meta notranslate" translate="no">
        {issueNum && <span>Issue {pad(issueNum)} · {formatDate(issueDate)}</span>}
      </div>
      <h3 class="card__title">
        <a href={href} set:html={article.title} />
      </h3>
      <p class="card__deck">{article.deck}</p>
    </Fragment>
  ) : variant === 'cover' ? (
    <Fragment>
      <h3 class="card__title">
        <a href={href} set:html={article.title} />
      </h3>
      <p class="card__deck">{article.deck}</p>
      <div class="card__byline">
        <a href={href}>Dawn Vision · {article.read_time} →</a>
      </div>
    </Fragment>
  ) : (
    <Fragment>
      {showCategory && categoryText && (
        <div class="card__category">{categoryText}</div>
      )}
      <h3 class="card__title">
        <a href={href} set:html={article.title} />
      </h3>
      <p class="card__deck">{article.deck}</p>
    </Fragment>
  )}
</article>
