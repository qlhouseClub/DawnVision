---
/**
 * Nav — 顶部导航栏
 * @param variant 'home' | 'inner' — 首页版（Klein蓝底白字）或内页版（白底磨砂玻璃吸顶）
 * @param active 当前激活的导航项: 'home' | 'articles' | 'cao' | 'about'
 *
 * 注意: 导航文本固定为英文，不翻译 (Home/Articles/Cao/About/Dawn Vision/Daily Briefing)
 */
import '@styles/components/nav.css';

export interface Props {
  variant?: 'home' | 'inner';
  active?: 'home' | 'articles' | 'cao' | 'about';
}

const { variant = 'inner', active } = Astro.props;
const isHome = variant === 'home';
---

<nav class={`nav nav--${variant} notranslate`} role="navigation" aria-label="主导航" data-pagefind-ignore translate="no">
  {isHome ? (
    <Fragment>
      <div class="nav__group">
        <a href="/" class={`nav__link ${active === 'home' ? 'nav__link--active' : ''}`} aria-current={active === 'home' ? 'page' : undefined}>Home</a>
        <a href="/articles/" class={`nav__link ${active === 'articles' ? 'nav__link--active' : ''}`} aria-current={active === 'articles' ? 'page' : undefined}>Articles</a>
      </div>
      <a href="/" class="nav__brand" aria-label="Dawn Vision 首页" translate="no">
        Dawn Vision
        <small>Daily Briefing</small>
      </a>
      <div class="nav__group">
        <a href="/cao/" class={`nav__link ${active === 'cao' ? 'nav__link--active' : ''}`} aria-current={active === 'cao' ? 'page' : undefined}>Cao</a>
        <a href="/about/" class={`nav__link ${active === 'about' ? 'nav__link--active' : ''}`} aria-current={active === 'about' ? 'page' : undefined}>About</a>
      </div>
    </Fragment>
  ) : (
    <div class="nav__inner">
      <div class="nav__group">
        <a href="/" class={`nav__link ${active === 'home' ? 'nav__link--active' : ''}`} aria-current={active === 'home' ? 'page' : undefined}>Home</a>
        <a href="/articles/" class={`nav__link ${active === 'articles' ? 'nav__link--active' : ''}`} aria-current={active === 'articles' ? 'page' : undefined}>Articles</a>
      </div>
      <a href="/" class="nav__brand" aria-label="Dawn Vision 首页" translate="no">
        Dawn Vision
        <small>Daily Briefing</small>
      </a>
      <div class="nav__group">
        <a href="/cao/" class={`nav__link ${active === 'cao' ? 'nav__link--active' : ''}`} aria-current={active === 'cao' ? 'page' : undefined}>Cao</a>
        <a href="/about/" class={`nav__link ${active === 'about' ? 'nav__link--active' : ''}`} aria-current={active === 'about' ? 'page' : undefined}>About</a>
      </div>
    </div>
  )}
</nav>
