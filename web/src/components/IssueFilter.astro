---
/**
 * IssueFilter — 期数四级联动筛选器
 * 年 → 月 → 上/下旬 → 期数
 * 纯静态HTML，客户端交互由is:inline脚本处理
 * 
 * 注意：选择框不包含无效占位选项，首项即为有效选项。
 */
import '@styles/components/issue-filter.css';
import { buildIssueFilterData } from '@lib/issues';

const filterData = await buildIssueFilterData();
const { tree, flat } = filterData;

// Serialize data for client script
const filterDataJson = JSON.stringify({ tree, flat });
---

<div class="issue-filter notranslate" id="issue-filter" data-filter={filterDataJson} translate="no">
  <div class="issue-filter__group">
    <select class="issue-filter__select" id="filter-year" aria-label="选择年份">
      {tree.map(y => (
        <option value={y.year}>{y.year}</option>
      ))}
    </select>
  </div>

  <div class="issue-filter__group">
    <select class="issue-filter__select" id="filter-month" aria-label="选择月份" disabled>
    </select>
  </div>

  <div class="issue-filter__group">
    <select class="issue-filter__select" id="filter-half" aria-label="选择上旬/下旬" disabled>
    </select>
  </div>

  <div class="issue-filter__group">
    <select class="issue-filter__select" id="filter-issue" aria-label="选择期数" disabled>
    </select>
  </div>
</div>

<script is:inline>
(function() {
  const container = document.getElementById('issue-filter');
  if (!container) return;

  let data;
  try {
    data = JSON.parse(container.getAttribute('data-filter') || '{}');
  } catch(_) { return; }

  const yearSel = document.getElementById('filter-year');
  const monthSel = document.getElementById('filter-month');
  const halfSel = document.getElementById('filter-half');
  const issueSel = document.getElementById('filter-issue');

  const monthNames = {
    '01': '1月', '02': '2月', '03': '3月', '04': '4月',
    '05': '5月', '06': '6月', '07': '7月', '08': '8月',
    '09': '9月', '10': '10月', '11': '11月', '12': '12月'
  };

  function pad(n) { return String(n).padStart(3, '0'); }

  function clearSelect(sel) {
    sel.innerHTML = '';
    sel.disabled = true;
  }

  function populateSelect(sel, options) {
    const frag = document.createDocumentFragment();
    options.forEach(opt => {
      const o = document.createElement('option');
      o.value = opt.value;
      o.textContent = opt.label;
      frag.appendChild(o);
    });
    sel.innerHTML = '';
    sel.appendChild(frag);
    sel.disabled = options.length === 0;
    // Auto-select first option
    if (options.length > 0) {
      sel.value = options[0].value;
    }
  }

  function onYearChange() {
    const year = yearSel.value;
    clearSelect(monthSel);
    clearSelect(halfSel);
    clearSelect(issueSel);
    if (!year) return;

    const yearData = data.tree.find(y => y.year === year);
    if (!yearData) return;

    const months = yearData.months.map(m => ({
      value: m.month,
      label: monthNames[m.month] || m.month
    }));
    populateSelect(monthSel, months);
    if (months.length > 0) onMonthChange();
  }

  function onMonthChange() {
    const year = yearSel.value;
    const month = monthSel.value;
    clearSelect(halfSel);
    clearSelect(issueSel);
    if (!year || !month) return;

    const yearData = data.tree.find(y => y.year === year);
    if (!yearData) return;
    const monthData = yearData.months.find(m => m.month === month);
    if (!monthData) return;

    const halves = monthData.halves.map(h => ({
      value: h.half,
      label: h.half === 'H1' ? '上半月' : '下半月'
    }));
    populateSelect(halfSel, halves);
    if (halves.length > 0) onHalfChange();
  }

  function onHalfChange() {
    const year = yearSel.value;
    const month = monthSel.value;
    const half = halfSel.value;
    clearSelect(issueSel);
    if (!year || !month || !half) return;

    const yearData = data.tree.find(y => y.year === year);
    if (!yearData) return;
    const monthData = yearData.months.find(m => m.month === month);
    if (!monthData) return;
    const halfData = monthData.halves.find(h => h.half === half);
    if (!halfData) return;

    const issues = halfData.issues.map(num => {
      const isLatest = data.flat[0] && data.flat[0].num === num;
      return {
        value: num,
        label: isLatest ? `Issue ${pad(num)} (最新)` : `Issue ${pad(num)}`
      };
    });
    populateSelect(issueSel, issues);
  }

  function onIssueChange() {
    const num = issueSel.value;
    if (!num) return;
    // Dispatch custom event with source='filter' to avoid loop
    document.dispatchEvent(new CustomEvent('issue-changed', { detail: { issue: num, source: 'filter' } }));
  }

  yearSel.addEventListener('change', onYearChange);
  monthSel.addEventListener('change', onMonthChange);
  halfSel.addEventListener('change', onHalfChange);
  issueSel.addEventListener('change', onIssueChange);

  // Initial setup
  function init() {
    // Check URL for pre-selected issue
    const urlParams = new URLSearchParams(window.location.search);
    const preIssue = urlParams.get('issue');
    if (preIssue) {
      setIssue(preIssue);
    } else {
      // Select latest issue by default
      if (yearSel.value) onYearChange();
    }
  }

  // Externally set issue (used by pagination/init to sync dropdowns)
  function setIssue(num) {
    const issue = data.flat.find(f => f.num === num);
    if (!issue) return;
    const [y, m] = issue.date.split('-');
    const day = parseInt(issue.date.split('-')[2]);
    const h = day <= 15 ? 'H1' : 'H2';

    yearSel.value = y;
    onYearChange();
    setTimeout(() => {
      monthSel.value = m;
      onMonthChange();
      setTimeout(() => {
        halfSel.value = h;
        onHalfChange();
        setTimeout(() => {
          issueSel.value = num;
          // Update issue label
          const label = document.getElementById('issue-label');
          if (label) label.textContent = 'Issue ' + pad(num);
        }, 50);
      }, 50);
    }, 50);
  }

  // Listen for external issue changes (from pagination clicks) - sync dropdowns only
  document.addEventListener('issue-changed', function(e) {
    if (e.detail && e.detail.issue && e.detail.source !== 'filter') {
      setIssue(e.detail.issue);
    }
  });

  init();
})();
</script>
