---
import '@styles/global.css';
import { siteConfig } from '@lib/config';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import SearchModal from '@components/SearchModal.astro';
import TipModal from '@components/TipModal.astro';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  /** Nav variant: 'home' for Klein bg hero, 'inner' for white sticky */
  navVariant?: 'home' | 'inner';
  /** Active nav item */
  activeNav?: 'home' | 'articles' | 'cao' | 'about';
  /** JSON-LD structured data strings */
  structuredData?: string | string[];
}

const {
  title = siteConfig.name,
  description = siteConfig.description,
  ogImage = '/images/og-image.png',
  canonical,
  type = 'website',
  noindex = false,
  navVariant = 'inner',
  activeNav,
  structuredData,
} = Astro.props;

const isHome = navVariant === 'home';

const fullTitle = title === siteConfig.name
  ? `${title} | ${siteConfig.tagline} — AI 深度观察日刊`
  : `${title} — ${siteConfig.name}`;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site ?? siteConfig.url).toString();
const ogImageURL = new URL(ogImage, Astro.site ?? siteConfig.url).toString();

const jsonLdArray = structuredData
  ? Array.isArray(structuredData) ? structuredData : [structuredData]
  : [];
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  {/* Anti-redirect guard: block cached old GT scripts from auto-redirecting */}
  <script is:inline>
  (function(){
    window.__dvAllowTranslate = true;
    window.googleTranslateElementInit = function(){ /* overridden by interactions */ };
    var isGT = function(u){ return typeof u==='string' && /translate\.google(apis)?\.com/.test(u); };
    var _a=window.location.assign, _r=window.location.replace, _o=window.open;
    window.location.assign = function(u){ if(isGT(u) && !window.__dvAllowTranslate){ console.warn('[DV] Blocked auto GT redirect'); return; } return _a.call(window.location,u); };
    window.location.replace = function(u){ if(isGT(u) && !window.__dvAllowTranslate){ console.warn('[DV] Blocked auto GT redirect'); return; } return _r.call(window.location,u); };
    window.open = function(){ if(isGT(arguments[0]) && !window.__dvAllowTranslate){ console.warn('[DV] Blocked auto GT popup'); return null; } return _o.apply(window,arguments); };
  })();
  </script>

  <title>{fullTitle}</title>
  <meta name="description" content={description}>
  <meta name="author" content={siteConfig.author}>
  <meta name="keywords" content="Dawn Vision, AI资讯, AI日报, 人工智能, 大模型, AI Agent, GPT, Claude, 具身智能, AI商业化, 一人公司, AI编程, 深度分析, AI观察, LLM, AIGC, 槽点, 吐槽, AI吐槽, Cao, AI吐槽专栏, AI趣闻, AI翻车, AI fails, AI roasting, tech rant, AI humor">

  {/* Canonical */}
  <link rel="canonical" href={canonicalURL}>

  {/* Favicon */}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="apple-touch-icon" href="/favicon.svg">

  {/* Fonts - preconnect and non-blocking load */}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700;900&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;0,8..60,900;1,8..60,400;1,8..60,600&family=Noto+Sans+SC:wght@400;500;700&display=swap" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700;900&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;0,8..60,900;1,8..60,400;1,8..60,600&family=Noto+Sans+SC:wght@400;500;700&display=swap"></noscript>

  {/* Open Graph */}
  <meta property="og:type" content={type}>
  <meta property="og:title" content={fullTitle}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:image" content={ogImageURL}>
  <meta property="og:site_name" content={siteConfig.name}>
  <meta property="og:locale" content="zh_CN">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:type" content="image/png">

  {/* Twitter Card */}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={fullTitle}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImageURL}>

  {/* Robots */}
  {noindex
    ? <meta name="robots" content="noindex, nofollow">
    : <meta name="robots" content="index, follow">
  }

  {/* Baidu mobile friendly */}
  <meta name="applicable-device" content="pc,mobile">
  <meta name="format-detection" content="telephone=no">
  <meta name="baidu-site-verification" content={siteConfig.seo.baiduVerify}>
  {siteConfig.seo.sogouVerify && <meta name="sogou_site_verification" content={siteConfig.seo.sogouVerify}>}
  {siteConfig.seo.so360Verify && <meta name="360-site-verification" content={siteConfig.seo.so360Verify}>}
  {siteConfig.seo.bingVerify && <meta name="msvalidate.01" content={siteConfig.seo.bingVerify}>}
  {siteConfig.seo.googleVerify && <meta name="google-site-verification" content={siteConfig.seo.googleVerify}>}

  {/* JSON-LD Structured Data */}
  {jsonLdArray.map(ld => (
    <script type="application/ld+json" set:html={ld} />
  ))}

  {/* Analytics: Cloudflare Web Analytics */}
  {siteConfig.analytics.cloudflareBeaconToken && (
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon={`{"token": "${siteConfig.analytics.cloudflareBeaconToken}"}`}
    />
  )}

  {/* Analytics: Baidu Tongji */}
  {siteConfig.analytics.baiduTongjiId && (
    <script is:inline>
      var _hmt = _hmt || [];
      (function() {
        var hm = document.createElement("script");
        hm.src = "https://hm.baidu.com/hm.js?" + BAIDU_TONGJI_ID;
        var s = document.getElementsByTagName("script")[0];
        s.parentNode.insertBefore(hm, s);
      })();
    </script>
  )}

  {/* GT UI Hiding CSS — injected before body renders to prevent flash */}
  <style is:inline>
    iframe.goog-te-banner-frame,
    iframe[class*="goog-te-banner"],
    iframe[id*="goog-te-banner"],
    .goog-te-gadget, .goog-te-gadget-icon, .goog-te-gadget-simple,
    .goog-te-gadget span, #google_translate_element, #google_translate_element *,
    .goog-te-spinner-pos, .goog-te-spinner,
    img[src*="translate_spinner"], img[src*="loading"],
    .goog-te-menu-frame, .goog-te-menu-value,
    .goog-te-balloon-frame, .goog-text-highlight,
    #goog-gt-tt, .goog-tooltip,
    iframe[src*="translate.google.com"],
    iframe[src*="translate.googleapis.com"],
    iframe[src*="translate_p"], iframe[src*="element/"],
    a[href*="goog-te"], .VIiyi, .JLqJ4b,
    .skiptranslate {
      display:none!important; visibility:hidden!important; opacity:0!important;
      width:0!important; height:0!important; max-width:0!important; max-height:0!important;
      overflow:hidden!important; pointer-events:none!important; position:absolute!important;
      top:-9999px!important; left:-9999px!important;
      margin:0!important; padding:0!important; border:0!important;
    }
    body, html { top:0!important; margin-top:0!important; }

    /* Floating language switch button */
    .dv-lang-switch {
      position: fixed;
      bottom: 24px;
      right: 24px;
      z-index: 900;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      border: none;
      background: #ffffff;
      color: #002FA7;
      font-size: 11px;
      font-weight: 700;
      font-family: 'Source Serif 4', 'Noto Serif SC', Georgia, serif;
      letter-spacing: 0.5px;
      cursor: pointer;
      box-shadow: 0 2px 16px rgba(0,0,0,0.12);
      transition: all 0.2s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
    }
    .dv-lang-switch:hover {
      background: #002FA7;
      color: #fff;
      transform: scale(1.08);
      box-shadow: 0 4px 24px rgba(0,47,167,0.3);
    }
    .dv-lang-switch:disabled {
      opacity: 0.6;
      cursor: wait;
      transform: none;
    }
    @media (max-width: 700px) {
      .dv-lang-switch {
        bottom: 16px;
        right: 16px;
        width: 40px;
        height: 40px;
        font-size: 10px;
      }
    }
  </style>

  <slot name="head" />
</head>
<body class={isHome ? 'home' : ''}>
  {isHome && (
    <style is:inline>
      body.home {
        min-height: 100vh;
        background: var(--color-brand);
        color: var(--color-white);
        position: relative;
        display: flex;
        flex-direction: column;
      }
    </style>
  )}
  <a href="#main-content" class="skip-link">跳至主要内容</a>

  {isHome ? (
    <Fragment>
      <Nav variant="home" active={activeNav} />
      <main id="main-content" style="flex:1; position:relative; z-index:1;">
        <slot name="main" />
      </main>
      <Footer variant="home" />
    </Fragment>
  ) : (
    <Fragment>
      <Nav variant="inner" active={activeNav} />
      <main id="main-content">
        <slot name="main" />
      </main>
      <Footer variant="site" />
    </Fragment>
  )}

  {/* Hidden GT element container */}
  <div id="google_translate_element" style="position:absolute;left:-9999px;top:-9999px;width:0;height:0;overflow:hidden;opacity:0;pointer-events:none;"></div>

  {/* Search Modal + Reading Progress */}
  <SearchModal />

  {/* Tip Modal */}
  <TipModal />

  {/* Client interactions */}
  <script>
    import '@scripts/interactions';
  </script>

  {/* 百度自动推送 - 异步加载不阻塞渲染 */}
  <script is:inline>
  window.addEventListener('load', function(){
    var bp = document.createElement('script');
    var curProtocol = window.location.protocol.split(':')[0];
    bp.src = (curProtocol === 'https' ? 'https://zz.bdstatic.com/linksubmit/push.js' : 'http://push.zhanzhang.baidu.com/push.js');
    bp.async = true;
    var s = document.getElementsByTagName("script")[0];
    s.parentNode.insertBefore(bp, s);
  });
  </script>
</body>
</html>
